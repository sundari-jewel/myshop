{
  "name": "sundari-jewels",
  "version": "0.1.0",
  "private": true,
  "description": "SEO-first jewellery ecommerce storefront built with Next.js and React.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run lint && npm run typecheck && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "setup:models": "node scripts/download-models.js"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "framer-motion": "^12.42.2",
    "jose": "^6.2.4",
    "lucide-react": "1.16.0",
    "mongoose": "^9.6.2",
    "next": "^16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-dropzone": "^15.0.0",
    "replicate": "^1.4.0",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "mongodb-memory-server": "^11.2.0",
    "msw": "^2.14.6",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
